{
  "$schema": "../../schema/framework.schema.json",
  "framework": "AI_DORA",
  "name": "AI-Modified DORA",
  "description": "AI-Modified DevOps Research and Assessment metrics for software delivery performance in AI-assisted environments",
  "version": "1.0.0",
  "basedOn": {
    "framework": "DORA",
    "name": "DevOps Research and Assessment",
    "source": "https://dora.dev",
    "version": "2023"
  },
  "category": "software-delivery-performance",
  "metrics": [
    {
      "id": "DF",
      "name": "Deployment Frequency",
      "description": "How often code is deployed to production",
      "direction": "higher_is_better",
      "unit": "deploys/day",
      "levels": {
        "elite": {
          "threshold": 10,
          "operator": ">=",
          "label": "10+ per day",
          "standardComparison": {
            "standardThreshold": "multiple per day",
            "accelerationFactor": "3-5x"
          }
        },
        "high": {
          "threshold": 3,
          "operator": ">=",
          "label": "Multiple per day",
          "standardComparison": {
            "standardThreshold": "daily to weekly",
            "accelerationFactor": "5-10x"
          }
        },
        "medium": {
          "threshold": 1,
          "operator": ">=",
          "label": "Daily",
          "standardComparison": {
            "standardThreshold": "weekly to monthly",
            "accelerationFactor": "7x"
          }
        },
        "low": {
          "threshold": 0.2,
          "operator": ">=",
          "label": "Weekly",
          "standardComparison": {
            "standardThreshold": "monthly+",
            "accelerationFactor": "4x"
          }
        }
      },
      "aiEnablers": [
        "AI code generation",
        "Automated test generation",
        "Intelligent CI/CD pipelines",
        "AI-assisted deployment decisions"
      ]
    },
    {
      "id": "LT",
      "name": "Lead Time for Changes",
      "description": "Time from code commit to running in production",
      "direction": "lower_is_better",
      "unit": "hours",
      "levels": {
        "elite": {
          "threshold": 2,
          "operator": "<=",
          "label": "< 2 hours",
          "standardComparison": {
            "standardThreshold": "< 1 day",
            "accelerationFactor": "12x"
          }
        },
        "high": {
          "threshold": 24,
          "operator": "<=",
          "label": "< 1 day",
          "standardComparison": {
            "standardThreshold": "1 day - 1 week",
            "accelerationFactor": "7x"
          }
        },
        "medium": {
          "threshold": 72,
          "operator": "<=",
          "label": "1-3 days",
          "standardComparison": {
            "standardThreshold": "1 week - 1 month",
            "accelerationFactor": "10x"
          }
        },
        "low": {
          "threshold": 168,
          "operator": "<=",
          "label": "1 week",
          "standardComparison": {
            "standardThreshold": "1 month+",
            "accelerationFactor": "4x"
          }
        }
      },
      "aiEnablers": [
        "AI pair programming",
        "AI-assisted code review",
        "AI test generation",
        "Automated documentation"
      ]
    },
    {
      "id": "CFR",
      "name": "Change Failure Rate",
      "description": "Percentage of deployments causing a failure in production",
      "direction": "lower_is_better",
      "unit": "%",
      "levels": {
        "elite": {
          "threshold": 2,
          "operator": "<=",
          "label": "0-2%",
          "standardComparison": {
            "standardThreshold": "0-5%",
            "accelerationFactor": "2.5x better"
          }
        },
        "high": {
          "threshold": 5,
          "operator": "<=",
          "label": "2-5%",
          "standardComparison": {
            "standardThreshold": "5-10%",
            "accelerationFactor": "2x better"
          }
        },
        "medium": {
          "threshold": 8,
          "operator": "<=",
          "label": "5-8%",
          "standardComparison": {
            "standardThreshold": "10-15%",
            "accelerationFactor": "1.8x better"
          }
        },
        "low": {
          "threshold": 12,
          "operator": "<=",
          "label": "8-12%",
          "standardComparison": {
            "standardThreshold": "15%+",
            "accelerationFactor": "1.5x better"
          }
        }
      },
      "aiEnablers": [
        "AI static analysis",
        "AI-generated test coverage",
        "AI security scanning",
        "AI code review"
      ]
    },
    {
      "id": "MTTR",
      "name": "Mean Time to Recovery",
      "description": "Time to restore service after a failure",
      "direction": "lower_is_better",
      "unit": "minutes",
      "levels": {
        "elite": {
          "threshold": 15,
          "operator": "<=",
          "label": "< 15 minutes",
          "standardComparison": {
            "standardThreshold": "< 1 hour",
            "accelerationFactor": "4x"
          }
        },
        "high": {
          "threshold": 120,
          "operator": "<=",
          "label": "< 2 hours",
          "standardComparison": {
            "standardThreshold": "< 1 day",
            "accelerationFactor": "12x"
          }
        },
        "medium": {
          "threshold": 1440,
          "operator": "<=",
          "label": "< 1 day",
          "standardComparison": {
            "standardThreshold": "1 day - 1 week",
            "accelerationFactor": "7x"
          }
        },
        "low": {
          "threshold": 4320,
          "operator": "<=",
          "label": "1-3 days",
          "standardComparison": {
            "standardThreshold": "1 week+",
            "accelerationFactor": "3x"
          }
        }
      },
      "aiEnablers": [
        "AI debugging assistants",
        "AI root cause analysis",
        "AI-powered runbooks",
        "AI fix suggestions"
      ]
    }
  ],
  "references": [
    {
      "title": "DORA Research Program",
      "url": "https://dora.dev"
    },
    {
      "title": "Accelerate: The Science of Lean Software and DevOps",
      "authors": ["Nicole Forsgren", "Jez Humble", "Gene Kim"],
      "year": 2018
    },
    {
      "title": "State of DevOps Report",
      "url": "https://cloud.google.com/devops/state-of-devops"
    }
  ]
}
